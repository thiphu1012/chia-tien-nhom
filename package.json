{
  "name": "tally-expense-bot",
  "version": "1.1.0",
  "private": true,
  "description": "Telegram Mini App expense splitter on Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local": "wrangler d1 execute tally --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute tally --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute tally --local --file=./migrations/0002_participant_transfer_info.sql",
    "db:migrate:remote": "wrangler d1 execute tally --remote --file=./migrations/0002_participant_transfer_info.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
