# Local setup values for the Makefile helpers (SETUP.md steps 7 & 8).
# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
#
#   cp .env.example .env
#
# These are the SAME values you set elsewhere:
#   BOT_TOKEN      — the BotFather token (also `wrangler secret put BOT_TOKEN`)
#   WEBHOOK_SECRET — your random string   (also `wrangler secret put WEBHOOK_SECRET`)
#   WEBAPP_URL     — the deployed Worker base URL, NO trailing slash, NO /webhook
#                    (must match wrangler.toml [vars].WEBAPP_URL)

BOT_TOKEN=123456:ABC-DEF_your_botfather_token
WEBHOOK_SECRET=your_random_hex_from_openssl_rand_hex_16
WEBAPP_URL=https://tally-expense-bot.YOUR-SUBDOMAIN.workers.dev
